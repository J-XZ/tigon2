{
  "shared_memory": {
    "size_mb": 512,
    "path": "/tmp/tigonkv-ycsb-backing",
    "device_path": "/dev/ivpci0",
    "hwcc": { "offset_mb": 0, "size_mb": 256 },
    "swcc": { "offset_mb": 256, "size_mb": 256 }
  },
  "vm": { "count": 2 },
  "tigon_kv": {
    "partition_count": 16,
    "fixed_key_size": 32,
    "fixed_value_size": 1000,
    "hw_cc_budget_mb": 256,
    "owner_private_swcc_fraction": 0.35,
    "migration_policy": "Clock",
    "when_to_move_out": "OnDemand",
    "scc_mechanism": "WriteThrough",
    "transport_ring_total_mb": 1,
    "latency_inject": {
      "enabled": false, "foreground_enabled": false, "merge_enabled": false,
      "stats_enabled": false, "cache_line_bytes": 64,
      "swcc_read_ns_per_line": 0, "swcc_write_ns_per_line": 0,
      "swcc_flush_ns_per_line": 0, "hwcc_read_ns_per_line": 0,
      "hwcc_write_ns_per_line": 0, "hwcc_atomic_load_ns": 0,
      "hwcc_atomic_store_ns": 0, "hwcc_atomic_rmw_ns": 0,
      "cache_model": "none", "cache_hits_enabled": false,
      "cache_capacity_lines": 0, "cache_associativity": 1,
      "cache_fixed_hit_rate": 0.0, "cache_hit_extra_ns": 0
    }
  }
}
