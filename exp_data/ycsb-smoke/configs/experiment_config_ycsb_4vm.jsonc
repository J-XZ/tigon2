  "shared_memory": {
    "device_path": "/dev/ivpci0",
    "hwcc": {
      "offset_mb": 0,
      "size_mb": 1024
    },
    "numa_node": 1,
    "path": "/dev/shm/tigonkv",
    "size_mb": 32768,
    "swcc": {
      "offset_mb": 1024,
      "size_mb": 31744
    }
  },
  "sync": {
    "timeout_sec": 60
  },
  "tigon_kv": {
    "fixed_key_size": 32,
    "fixed_value_size": 1000,
    "hw_cc_budget_mb": 1024,
    "latency_inject": {
      "cache_associativity": 1,
      "cache_capacity_lines": 0,
      "cache_fixed_hit_rate": 0.0,
      "cache_hit_extra_ns": 0,
      "cache_hits_enabled": false,
      "cache_line_bytes": 64,
      "cache_model": "none",
      "enabled": false,
      "foreground_enabled": false,
      "hwcc_atomic_load_ns": 0,
      "hwcc_atomic_rmw_ns": 0,
      "hwcc_atomic_store_ns": 0,
      "hwcc_read_ns_per_line": 0,
      "hwcc_write_ns_per_line": 0,
      "merge_enabled": false,
      "stats_enabled": false,
      "swcc_flush_ns_per_line": 0,
      "swcc_read_ns_per_line": 0,
      "swcc_write_ns_per_line": 0
    },
    "migration_policy": "Clock",
    "owner_private_swcc_fraction": 0.35,
    "partition_count": 16,
    "scc_mechanism": "WriteThrough",
    "transport_ring_total_mb": 16,
    "when_to_move_out": "OnDemand"
  },
  "vm": {
    "bridge_tap_ip": "192.168.100.1",
    "copy_root_img": true,
    "core_count_per_vm": 8,
    "count": 4,
